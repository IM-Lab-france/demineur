[Unit]
Description=Envoi de la file e-mail du Démineur
After=network-online.target mysql.service

[Service]
Type=oneshot
User=minesweeper
Group=minesweeper
EnvironmentFile=/var/www/secure/minesweeper-service.env
Environment=APP_CONFIG_DIR=/var/www/secure
Environment=XDEBUG_MODE=off
ExecStart=/usr/bin/php /var/www/demineur/scripts/process-mail-queue.php
Nice=10

[Install]
WantedBy=multi-user.target
